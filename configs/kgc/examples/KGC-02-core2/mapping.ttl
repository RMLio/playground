@prefix rml: <http://w3id.org/rml/>.
@prefix dbo: <http://dbpedia.org/ontology/>.
@prefix foaf: <http://xmlns.com/foaf/0.1/>.

<#AuthorMapping> a rml:TriplesMap;
  rml:logicalSource [
    a rml:LogicalSource;
    rml:source [
      a rml:RelativePathSource;
      rml:root rml:MappingDirectory;
      rml:path "authors.json";
    ];
    rml:referenceFormulation rml:JSONPath;
    rml:iterator "$[*]";
  ];
  rml:subjectMap [
    a rml:SubjectMap;
    rml:template "http://example.com/author/{id}";
  ];
  rml:predicateObjectMap [
    a rml:PredicateObjectMap;
    rml:predicate foaf:name;
    rml:objectMap [
      a rml:ObjectMap;
      rml:reference "name";
    ];
  ].

<#BookMapping> a rml:TriplesMap;
  rml:logicalSource [
    a rml:LogicalSource;
    rml:source [
      a rml:Source, rml:RelativePathSource;
      rml:root rml:MappingDirectory;
      rml:path "books.json";
    ];
    rml:referenceFormulation rml:JSONPath;
    rml:iterator "$[*]";
  ];
  rml:subjectMap [
    a rml:SubjectMap;
    rml:template "http://example.com/book/{id}";
  ];
  rml:predicateObjectMap [
    rml:predicate dbo:title;
    rml:objectMap [
      a rml:ObjectMap;
      rml:reference "title";
    ];
  ], [
    rml:predicate dbo:author;
    rml:objectMap [
      a rml:RefObjectMap;
      rml:parentTriplesMap <#AuthorMapping>;
      rml:joinCondition [
        rml:child "author_id";
        rml:parent "id";
      ];
    ];
  ].

