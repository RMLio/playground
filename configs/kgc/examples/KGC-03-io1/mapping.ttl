@prefix rml: <http://w3id.org/rml/>.
@prefix map: <http://mapping.example.com/>.
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix schema: <http://schema.org/>.
@prefix ex: <http://example.com/>.

map:movie a rml:TriplesMap;
  rml:logicalSource [
    a rml:LogicalSource;
    rml:referenceFormulation rml:CSV;
    rml:source [
      a rml:RelativePathSource;
      rml:path "movies.csv";
    ];
  ];
  rml:subjectMap [
    a rml:SubjectMap;
    rml:template "http://example.com/movie/{slug}";
    rml:class schema:Movie;
  ];
  rml:predicateObjectMap [
    a rml:PredicateObjectMap;
    rml:predicate schema:name;
    rml:objectMap [
      a rml:ObjectMap;
      rml:reference "title";
    ];
  ], [
    rml:predicate ex:year;
    rml:objectMap [
      a rml:ObjectMap;
      rml:reference "year";
    ];
  ].

map:person a rml:TriplesMap;
  rml:logicalSource [
    a rml:LogicalSource;
    rml:iterator "$.persons[*]";
    rml:referenceFormulation rml:JSONPath;
    rml:source [
      a rml:RelativePathSource;
      rml:path "persons.json";
    ];
  ];
  rml:subjectMap [
    rml:template "http://example.com/person/{firstname}";
    rml:class foaf:Person;
  ];
  rml:predicateObjectMap [
    rml:predicate ex:name;
    rml:objectMap [ rml:reference "firstname" ];
  ], [
    rml:predicate ex:likes;
    rml:objectMap [
      a rml:RefObjectMap;
      rml:joinCondition [
        rml:child "movie";
        rml:parent "slug";
      ];
      rml:parentTriplesMap map:movie;
    ];
  ].

