@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix map: <http://mapping.example.com/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

map:dcat_000 rdf:type <http://www.w3.org/ns/dcat#Dataset> ;
    <http://www.w3.org/ns/dcat#dataDump> <file:///data/dump1.nt> .

map:map_person_000 rml:logicalSource map:source_000 ;
    rdf:type rr:TriplesMap ;
    rdfs:label "person" ;
    rr:predicateObjectMap map:pom_000, map:pom_001 ;
    rr:subjectMap map:s_000 .

map:om_000 rml:reference "./name" ;
    rdf:type rr:ObjectMap ;
    rr:termType rr:Literal .

map:om_001 rml:reference "./nickname" ;
    rdf:type rr:ObjectMap ;
    rr:termType rr:Literal .

map:pm_000 rml:logicalTarget map:target_001 ;
    rdf:type rr:PredicateMap ;
    rr:constant foaf:name .

map:pm_001 rdf:type rr:PredicateMap ;
    rr:constant foaf:nickname .

map:pom_000 rdf:type rr:PredicateObjectMap ;
    rr:objectMap map:om_000 ;
    rr:predicateMap map:pm_000 .

map:pom_001 rdf:type rr:PredicateObjectMap ;
    rr:objectMap map:om_001 ;
    rr:predicateMap map:pm_001 .

map:rules_000 <http://rdfs.org/ns/void#exampleResource> map:map_person_000 ;
    rdf:type <http://rdfs.org/ns/void#Dataset> .

map:s_000 rml:logicalTarget map:target_000 ;
    rdf:type rr:SubjectMap ;
    rr:template "http://example.org/{./@id}" .

map:source_000 rml:iterator "/Supergirl/Character" ;
    rml:referenceFormulation ql:XPath ;
    rml:source "Supergirl.xml" ;
    rdf:type rml:LogicalSource ;
    rdfs:label "supergirl-source" .

map:target_000 <http://semweb.mmlab.be/ns/rml-target#serialization> <http://www.w3.org/ns/formats/N-Triples> ;
    <http://semweb.mmlab.be/ns/rml-target#target> map:dcat_000 ;
    rdf:type <http://semweb.mmlab.be/ns/rml-target#LogicalTarget> ;
    rdfs:label "target1" .

map:target_001 <http://semweb.mmlab.be/ns/rml-target#serialization> <http://www.w3.org/ns/formats/Turtle> ;
    <http://semweb.mmlab.be/ns/rml-target#target> map:void_000 ;
    rdf:type <http://semweb.mmlab.be/ns/rml-target#LogicalTarget> ;
    rdfs:label "target2" .

map:void_000 <http://rdfs.org/ns/void#dataDump> <file:///data/dump2.ttl> ;
    rdf:type <http://rdfs.org/ns/void#Dataset> .