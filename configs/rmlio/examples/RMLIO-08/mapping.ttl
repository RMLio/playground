@prefix rr:            <http://www.w3.org/ns/r2rml#> .
@prefix rml:           <http://semweb.mmlab.be/ns/rml#> .
@prefix rdf:           <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:          <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ql:            <http://semweb.mmlab.be/ns/ql#> .
@prefix map:           <http://mapping.example.com/> .
@prefix era:           <http://data.europa.eu/949/> .
@prefix era-op-types:  <http://data.europa.eu/949/concepts/op-types/rinf/> .
@prefix era-tenclass:  <http://data.europa.eu/949/concepts/ten-classifications/rinf/> .
@prefix era-linecat:   <http://data.europa.eu/949/concepts/line-category/rinf/> .
@prefix era-fc:        <http://data.europa.eu/949/concepts/freight-corridor/rinf/> .

map:map_op_000

    rml:logicalSource map:source_000 ;
    rr:subjectMap [

        rr:template "http://data.europa.eu/949/functionalInfrastructure/operationalPoints/{UniqueOPID/@Value}"
    ] ;
    rr:predicateObjectMap [

        rr:predicate rdf:type ;
        rr:object era:OperationalPoint
    ], [

        rr:predicate era:opName ;
        rr:objectMap [

            rml:reference "OPName/@Value" ;
        ]
    ], [

        rr:predicate era:opType ;
        rr:objectMap [

            rr:template "http://data.europa.eu/949/concepts/op-types/rinf/{OPType/@Value}" ;
        ]
    ], [

        rr:predicate era:uopid ;
        rr:objectMap [

            rml:reference "UniqueOPID/@Value" ;
        ]
    ] .

map:map_track_000

    rml:logicalSource map:source_001 ;
    rr:subjectMap [

        rr:template "http://data.europa.eu/949/functionalInfrastructure/tracks/{OPTrackIdentification/@Value}"
    ] ;
    rr:predicateObjectMap [

        rr:predicate rdf:type ;
        rr:object era:Track
    ], [

        rr:predicate era:uopid ;
        rr:objectMap [

            rml:reference "OPTrackIdentification/@Value" ;
        ]
    ] .

map:map_link_000

    rml:logicalSource map:source_000 ;
    rr:subjectMap [

        rr:template "http://data.europa.eu/949/functionalInfrastructure/operationalPoints/{UniqueOPID/@Value}"
    ] ;
    rr:predicateObjectMap [

        rr:predicate era:track ;
        rr:objectMap [

            rr:template "http://data.europa.eu/949/functionalInfrastructure/tracks/{OPTrack/OPTrackIdentification/@Value}" ;
        ]
    ] .

map:source_000

    rml:source "rinf_test.xml" ;
    rml:referenceFormulation ql:XPath ;
    rml:iterator "/RINFData/OperationalPoint" .

map:source_001

    rml:source "rinf_test.xml" ;
    rml:referenceFormulation ql:XPath ;
    rml:iterator "/RINFData/OperationalPoint/OPTrack" .
